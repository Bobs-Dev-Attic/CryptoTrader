# --- Core ---
# Set ENVIRONMENT=production to enable strict startup checks: the app will
# REFUSE to start if JWT_SECRET is the default or ENCRYPTION_KEY is unset.
# Set the secrets below FIRST, then flip this to production.
ENVIRONMENT=development
# Off by default. Only enable for local debugging — never in production.
DEBUG=false

# SQLite by default; swap for Postgres in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/cryptotrader
DATABASE_URL=sqlite:///./cryptotrader.db

# --- Auth (CHANGE THESE IN PRODUCTION) ---
JWT_SECRET=change-me-in-production-please
# Short-lived access token; clients silently refresh with the 30-day refresh token.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Fernet key used to encrypt exchange API credentials at rest. INDEPENDENT of
# JWT_SECRET — required in production. If unset, a key is derived from JWT_SECRET
# (dev only). Setting this makes it the primary key while the derived key stays a
# decrypt fallback, so existing encrypted credentials keep working (safe rotation).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- LLM agents (optional) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- Scheduler ---
SCHEDULER_ENABLED=true
MIN_AGENT_INTERVAL_SECONDS=30
# Shared secret for the external cron tick (serverless). Set the SAME value as
# Vercel's CRON_SECRET (or the secret your Supabase pg_cron job sends).
INTERNAL_CRON_SECRET=

# --- CORS (comma-separated allowed browser origins) ---
# In production the UI is served SAME-ORIGIN (single Vercel project), so this
# usually needs no entry. The default opens only local Expo web dev ports. Set
# explicit origins if you serve the frontend from a different domain; avoid `*`.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
