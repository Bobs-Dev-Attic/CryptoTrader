# --- Core ---
ENVIRONMENT=development
DEBUG=true

# SQLite by default; swap for Postgres in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/cryptotrader
DATABASE_URL=sqlite:///./cryptotrader.db

# --- Auth (CHANGE THESE IN PRODUCTION) ---
JWT_SECRET=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Fernet key used to encrypt exchange API credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- LLM agents (optional) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- Scheduler ---
SCHEDULER_ENABLED=true
MIN_AGENT_INTERVAL_SECONDS=30

# --- CORS (comma-separated, or * for all) ---
CORS_ORIGINS=*
